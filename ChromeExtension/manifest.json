{
  "manifest_version": 3,
  "name": "Ownggle — History to Meilisearch",
  "version": "1.0",
  "description": "Index your browsing history into your own Meilisearch instance and search it at own.kerollmops.com.",
  "permissions": ["history", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
